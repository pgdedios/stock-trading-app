<!-- Ransack Search Form -->
<div class="px-6 py-4 text-sm border-b border-gray-200 bg-white w-full">
  <%= search_form_for @q, url: transactions_path, local: true, 
      class: "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 items-end justify-between" do |f| %>

    <!-- Search by stock symbol or company name -->
    <div class="sm:col-span-2 space-y-1">
      <%= f.label :stock_symbol_or_company_name_cont, "Company / Stock Symbol",
          class: "block text-xs font-semibold text-gray-600 uppercase tracking-wide" %>
      <%= f.search_field :stock_symbol_or_company_name_cont,
          placeholder: "Search company or symbol...",
          class: "w-full px-4 py-2 bg-white border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition ease-in-out duration-150" %>
    </div>

    <!-- Filter by transaction type -->
    <div class="space-y-1">
      <%= f.label :transaction_type_eq, "Transaction Type",
          class: "block text-xs font-semibold text-gray-600 uppercase tracking-wide" %>
      <div class="relative">
        <%= f.select :transaction_type_eq,
            options_for_select(
              [['All Types', ''], ['Buy', 'buy'], ['Sell', 'sell']],
              @q.transaction_type_eq
            ),
            { include_blank: false },
            {
              class: "w-full px-4 py-2 bg-white border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 appearance-none",
              "data-turbo": false
            }
        %>
        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-gray-700">
          <svg class="h-5 w-5 text-gray-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
      </div>
    </div>

    <!-- Actions -->
    <div class="flex flex-col sm:flex-row sm:justify-end gap-2 pt-1">
      <%= f.submit "Search", 
          class: "px-5 py-2.5 bg-blue-600 text-white font-medium rounded-3xl hover:bg-blue-700 focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 focus:outline-none transition ease-in-out duration-150 shadow-sm" %>
      <%= link_to "Clear", transactions_path, 
          class: "px-5 py-2.5 bg-gray-200 text-gray-800 font-medium rounded-3xl hover:bg-gray-300 focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 focus:outline-none transition ease-in-out duration-150 shadow-sm text-center" %>
    </div>
  <% end %>
</div>