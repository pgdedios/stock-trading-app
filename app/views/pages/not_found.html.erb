<div class="min-h-screen flex flex-col items-center justify-center bg-gray-100 text-center px-4">
  <!-- SVG Animation -->
  <div class="w-32 h-32 mb-6 animate-bounce">
    <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
      <circle cx="100" cy="100" r="100" fill="#E2E8F0"/>
      <text x="50%" y="50%" text-anchor="middle" fill="#3B82F6" font-size="48" font-weight="bold" dy=".3em">404</text>
    </svg>
  </div>

  <!-- Headline -->
  <h1 class="text-3xl font-bold text-gray-800 mb-2">Page Not Found</h1>

  <!-- Description -->
  <p class="text-gray-600 mb-6">
    Sorry, we couldn't find the page you're looking for.<br>
    It might have been moved, deleted, or entered incorrectly.
  </p>

  <!-- Action Buttons -->
  <div class="flex gap-4 mb-4">
    <%= link_to "Go Home", root_path, class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition" %>
    <button onclick="history.back()" class="px-4 py-2 bg-gray-300 text-gray-800 rounded hover:bg-gray-400 transition">Go Back</button>
  </div>
</div>
