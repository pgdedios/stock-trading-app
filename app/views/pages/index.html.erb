<div class="min-h-screen bg-gray-100">
  <!-- Sticky Navbar -->
  <div class="sticky top-0 z-50 shadow-md">
    <%= render "shared/navbar" %>
  </div>

  <!-- Main Content -->
  <div class="max-w-7xl mx-auto px-4 py-8">
    <!-- Dashboard Header -->
    <%= render 'shared/page_header', 
        title: 'Dashboard', 
        subtitle: 'Overview of your account' %>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <!-- Balance Card -->
      <div class="bg-white p-6 rounded-lg shadow">
        <div class="flex items-center">
          <div class="p-2 bg-green-100 rounded-lg">
            <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-600">Current Balance</p>
            <p class="text-2xl font-semibold text-gray-900"><%= number_to_currency(current_user.balance) %></p>
          </div>
        </div>
      </div>

      <!-- Stock Companies -->
      <div class="bg-white p-6 rounded-lg shadow">
        <div class="flex items-center">
          <div class="p-2 bg-purple-100 rounded-lg">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6 text-purple-600">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75h15A2.25 2.25 0 0 1 21.75 12v.75m-8.69-6.44-2.12-2.12a1.5 1.5 0 0 0-1.061-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.379a1.5 1.5 0 0 1-1.06-.44Z" />
            </svg>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-600">Total Holdings</p>
            <p class="text-2xl font-semibold text-gray-900"><%= current_user.portfolios.count %></p>
          </div>
        </div>
      </div>

      <!-- Transactions Card -->
      <div class="bg-white p-6 rounded-lg shadow">
        <div class="flex items-center">
          <div class="p-2 bg-blue-100 rounded-lg">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6 text-blue-600">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
            </svg>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-600">Total Transactions</p>
            <p class="text-2xl font-semibold text-gray-900"><%= current_user.transactions.count %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Recent Transactions -->
    <div class="mb-8 bg-white rounded-lg shadow overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
        <h2 class="text-lg font-semibold text-gray-900">Recent Transactions</h2>
        <%= link_to "View All", transactions_path, class: "text-blue-600 hover:text-blue-800 text-sm font-medium" %>
      </div>
      <div class="overflow-x-auto">
        <%= render "transactions/transactions", locals: { transactions: @recent_transactions } %>
      </div>
    </div>

    <!-- Recently Acquired Stocks -->
    <div class="mb-8 bg-white rounded-lg shadow overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
        <h2 class="text-lg font-semibold text-gray-900">Recently Acquired Stocks</h2>
        <%= link_to "View All", portfolios_path, class: "text-blue-600 hover:text-blue-800 text-sm font-medium" %>
      </div>
      <div class="overflow-x-auto">
        <%= render "portfolios/portfolios", locals: { portfolios: @recent_portfolios } %>
      </div>
    </div>
  </div>
</div>