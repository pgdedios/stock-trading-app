<div class="mb-8">
  <div class="flex justify-between items-start">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Transaction Details</h1>
      <p class="mt-2 text-gray-600">Transaction ID: #<%= @transaction.id %></p>
    </div>
    <%= link_to "Back to Transactions", admin_transactions_path, 
        class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
  <!-- Transaction Information -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
      <h3 class="text-lg font-semibold text-gray-900">Transaction Information</h3>
    </div>
    <div class="p-6 space-y-4">
      <div class="flex justify-between items-center">
        <span class="text-sm font-medium text-gray-500">Transaction Type</span>
        <%= render 'admin/shared/transaction_badge', transaction: @transaction %>
      </div>
      
      <div class="flex justify-between items-center">
        <span class="text-sm font-medium text-gray-500">Stock Symbol</span>
        <span class="text-sm font-bold text-gray-900"><%= @transaction.stock_symbol %></span>
      </div>
      
      <div class="flex justify-between items-center">
        <span class="text-sm font-medium text-gray-500">Company Name</span>
        <span class="text-sm text-gray-900"><%= @transaction.company_name %></span>
      </div>
      
      <div class="flex justify-between items-center">
        <span class="text-sm font-medium text-gray-500">Quantity</span>
        <span class="text-sm text-gray-900"><%= @transaction.quantity %> shares</span>
      </div>
      
      <div class="flex justify-between items-center">
        <span class="text-sm font-medium text-gray-500">Price per Share</span>
        <span class="text-sm text-gray-900">$<%= number_with_precision(@transaction.price_at_time, precision: 2) %></span>
      </div>
      
      <div class="flex justify-between items-center pt-4 border-t border-gray-200">
        <span class="text-base font-semibold text-gray-700">Total Amount</span>
        <span class="text-base font-bold text-gray-900">$<%= number_with_precision(@transaction.total_amount, precision: 2) %></span>
      </div>
      
      <div class="flex justify-between items-center">
        <span class="text-sm font-medium text-gray-500">Transaction Date</span>
        <span class="text-sm text-gray-900"><%= @transaction.created_at.strftime("%B %d, %Y at %I:%M %p") %></span>
      </div>
    </div>
  </div>

  <!-- Trader Information -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
      <h3 class="text-lg font-semibold text-gray-900">Trader Information</h3>
    </div>
    <div class="p-6">
      <div class="flex items-center space-x-4 mb-6">
        <div class="h-16 w-16 bg-gray-300 rounded-full flex items-center justify-center">
          <span class="text-xl font-medium text-gray-700">
            <%= @trader.first_name.first %><%= @trader.last_name.first %>
          </span>
        </div>
        <div>
          <h4 class="text-lg font-semibold text-gray-900">
            <%= @trader.first_name %> <%= @trader.last_name %>
          </h4>
          <p class="text-sm text-gray-600"><%= @trader.email %></p>
          <div class="flex items-center space-x-2 mt-1">
            <%= render 'admin/shared/status_badge', user: @trader %>
          </div>
        </div>
      </div>
      
      <div class="space-y-3">
        <div class="flex justify-between items-center">
          <span class="text-sm font-medium text-gray-500">Current Balance</span>
          <span class="text-sm text-gray-900">$<%= number_with_precision(@trader.balance, precision: 2) %></span>
        </div>
        
        <div class="flex justify-between items-center">
          <span class="text-sm font-medium text-gray-500">Total Transactions</span>
          <span class="text-sm text-gray-900"><%= @trader.total_trades %></span>
        </div>
        
        <div class="flex justify-between items-center">
          <span class="text-sm font-medium text-gray-500">Portfolio Positions</span>
          <span class="text-sm text-gray-900"><%= @trader.portfolios.count %></span>
        </div>
        
        <div class="flex justify-between items-center">
          <span class="text-sm font-medium text-gray-500">Member Since</span>
          <span class="text-sm text-gray-900"><%= @trader.created_at.strftime("%B %d, %Y") %></span>
        </div>
      </div>
      
      <div class="mt-6 pt-4 border-t border-gray-200">
        <%= link_to "View Trader Profile", admin_trader_path(@trader), 
            class: "w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
      </div>
    </div>
  </div>
</div>