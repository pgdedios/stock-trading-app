<%= render 'admin/shared/page_header',
    title: 'All Transactions',
    subtitle: 'Monitor all trading activity across the platform' %>

<!-- Statistics Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center">
      <div class="p-2 bg-blue-100 rounded-lg">
        <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
        </svg>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-600">Total Transactions</p>
        <p class="text-2xl font-semibold text-gray-900"><%= @stats[:total_transactions] %></p>
      </div>
    </div>
  </div>
  
  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center">
      <div class="p-2 bg-green-100 rounded-lg">
        <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5-5m0 0l5 5m-5-5v12"></path>
        </svg>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-600">Buy Orders</p>
        <p class="text-2xl font-semibold text-green-600"><%= @stats[:total_buy_transactions] %></p>
      </div>
    </div>
  </div>
  
  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center">
      <div class="p-2 bg-red-100 rounded-lg">
        <svg class="h-6 w-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 13l-5 5m0 0l-5-5m5 5V6"></path>
        </svg>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-600">Sell Orders</p>
        <p class="text-2xl font-semibold text-red-600"><%= @stats[:total_sell_transactions] %></p>
      </div>
    </div>
  </div>
  
  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center">
      <div class="p-2 bg-purple-100 rounded-lg">
        <svg class="h-6 w-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
        </svg>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-600">Total Volume</p>
        <p class="text-2xl font-semibold text-gray-900">$<%= number_with_precision(@stats[:total_transaction_value], precision: 2) %></p>
      </div>
    </div>
  </div>
</div>

<!-- Ransack Search Bar -->
<div class="bg-white rounded-lg shadow-sm border border-gray-100 mb-6">
  <div class="p-6">
    <%= search_form_for @q, url: admin_transactions_path, local: true, class: "grid grid-cols-1 md:grid-cols-16 gap-6" do |f| %>
      <!-- Search by stock symbol or company name -->
      <div class="md:col-span-5">
        <%= f.search_field :stock_symbol_or_company_name_cont,
            placeholder: "Search stock/company...",
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 shadow-sm" %>
      </div>
      
      <!-- Filter by transaction type -->
      <div class="md:col-span-2 text-center">
        <%= f.select :transaction_type_eq,
            options_for_select([
              ['All Types', ''],
              ['Buy', 'buy'],
              ['Sell', 'sell']
            ], f.object.transaction_type_eq),
            {},
            { class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 shadow-sm bg-white appearance-none text-center" } %>
      </div>
      
      <!-- Filter by trader -->
      <div class="md:col-span-5 text-center">
        <%= f.collection_select :user_id_eq,
            User.traders.approved.order(:first_name, :last_name),
            :id,
            ->(user) { full_name_with_email(user) },
            { prompt: 'All Traders' },
            { class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 shadow-sm bg-white appearance-none text-center" } %>
      </div>
      
      <!-- Date range: Start date -->
      <div class="md:col-span-2 text-center">
        <%= f.date_field :created_at_gteq,
            placeholder: "Start date",
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 shadow-sm text-center placeholder:text-center" %>
      </div>
      
      <!-- Date range: End date -->
      <div class="md:col-span-2 text-center">
        <%= f.date_field :created_at_lteq,
            placeholder: "End date",
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 shadow-sm text-center placeholder:text-center" %>
      </div>
      
      <!-- Search and Clear buttons -->
      <div class="md:col-span-16 md:flex md:justify-center">
        <div class="flex space-x-2 md:w-auto w-full">
          <%= f.submit "Search", class: "flex-1 md:flex-none md:px-8 px-4 py-3 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200 shadow-sm" %>
          <%= link_to "Clear", admin_transactions_path, class: "flex-1 md:flex-none md:px-8 px-4 py-3 bg-gray-100 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 transition-all duration-200 shadow-sm text-center" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Table with Empty State -->
<% if @transactions.any? %>
  <!-- Transactions Table with Sorting -->
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Trader</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              <%= sort_link(@q, :stock_symbol, "Stock") %>
            </th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              <%= sort_link(@q, :transaction_type, "Type") %>
            </th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              <%= sort_link(@q, :quantity, "Quantity") %>
            </th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              <%= sort_link(@q, :price_at_time, "Price") %>
            </th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              <%= sort_link(@q, :total_amount, "Total") %>
            </th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              <%= sort_link(@q, :created_at, "Date") %>
            </th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @transactions.each do |transaction| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <%= render 'admin/shared/trader_info', trader: transaction.user %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div>
                  <p class="text-sm font-medium text-gray-900"><%= transaction.stock_symbol %></p>
                  <p class="text-xs text-gray-500"><%= transaction.company_name %></p>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= render 'admin/shared/transaction_badge', transaction: transaction %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <%= transaction.quantity %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                $<%= number_with_precision(transaction.price_at_time, precision: 2) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                $<%= number_with_precision(transaction.total_amount, precision: 2) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= transaction.created_at.strftime("%m/%d/%Y %I:%M %p") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <div class="flex items-center justify-end">
                  <%= link_to "View", admin_transaction_path(transaction),
                      class: "inline-flex items-center px-3 py-1.5 border border-gray-300 text-xs font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 transition-colors duration-150" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% else %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden">
    <div class="text-center py-16">
      <svg class="mx-auto h-16 w-16 text-gray-300 mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
      </svg>
      <h3 class="text-xl font-semibold text-gray-900 mb-2">
        <% if params[:q].present? %>
          No transactions match your search
        <% else %>
          No transactions found
        <% end %>
      </h3>
      <p class="text-gray-500 mb-6 max-w-sm mx-auto">
        <% if params[:q].present? %>
          Try adjusting your search criteria to find what you're looking for.
        <% else %>
          Transactions will appear here once traders start trading.
        <% end %>
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <% if params[:q].present? %>
          <%= link_to "Clear Search", admin_transactions_path, 
              class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 transition-colors duration-200" %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>