<%= link_to path, class: "block p-4 border-2 border-dashed border-gray-300 rounded-lg hover:border-blue-400 hover:bg-blue-50 transition-colors" do %>
  <div class="text-center">
    <%= render "admin/shared/icons/#{icon}", class: "mx-auto h-8 w-8 text-gray-400 mb-2" %>
    <p class="text-sm font-medium text-gray-900"><%= title %></p>
    <p class="text-xs text-gray-500"><%= subtitle %></p>
  </div>
<% end %>