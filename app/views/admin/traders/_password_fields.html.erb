<% if trader.persisted? %>
  <div class="bg-yellow-50 border border-yellow-200 rounded-md p-4">
    <div class="flex">
      <svg class="h-5 w-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
      </svg>
      <div class="ml-3">
        <p class="text-sm text-yellow-800">
          Leave password fields empty to keep the current password unchanged.
        </p>
      </div>
    </div>
  </div>
<% end %>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <div>
    <%= form.label :password, 
        trader.persisted? ? "New Password (optional)" : "Password", 
        class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.password_field :password, 
        class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-blue-500 focus:border-blue-500",
        placeholder: trader.persisted? ? "Leave empty to keep current password" : "Enter password" %>
    <% unless trader.persisted? %>
      <p class="mt-1 text-xs text-gray-500">Minimum 6 characters</p>
    <% end %>
  </div>

  <div>
    <%= form.label :password_confirmation, 
        trader.persisted? ? "Confirm New Password" : "Confirm Password",
        class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.password_field :password_confirmation, 
        class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-blue-500 focus:border-blue-500",
        placeholder: "Confirm password" %>
  </div>
</div>