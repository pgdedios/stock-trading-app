<div class="mt-4 pt-4 border-t border-gray-200">
  <div class="grid grid-cols-2 gap-4 text-sm">
    <div>
      <span class="font-medium text-gray-500">Initial Balance:</span>
      <span class="ml-2 text-gray-900">$<%= number_with_precision(trader.balance, precision: 2) %></span>
    </div>
    <div>
      <span class="font-medium text-gray-500">Account Status:</span>
      <span class="ml-2 font-medium <%= trader.can_trade? ? 'text-green-600' : trader.confirmed_at ? 'text-yellow-600' : 'text-red-600' %>">
        <%= trader.status %>
      </span>
    </div>
  </div>
</div>