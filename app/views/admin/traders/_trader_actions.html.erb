<div class="flex space-x-3">
  <%= link_to "View Details", admin_trader_path(trader), 
      class: "inline-flex items-center px-3 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
  
  <%= form_with url: approve_admin_trader_path(trader), method: :patch, local: true, 
      data: { confirm: "Are you sure you want to approve #{trader.first_name} #{trader.last_name}?" },
      style: "display: inline;" do %>
    <%= submit_tag "Approve", class: "inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 cursor-pointer" %>
  <% end %>
  
  <%= form_with url: reject_admin_trader_path(trader), method: :patch, local: true,
      data: { confirm: "Are you sure you want to reject #{trader.first_name} #{trader.last_name}?" },
      style: "display: inline;" do %>
    <%= submit_tag "Reject", class: "inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 cursor-pointer" %>
  <% end %>
</div>