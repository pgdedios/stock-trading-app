<div>
  <%= form.label :balance, class: "block text-sm font-medium text-gray-700 mb-2" %>
  <%= form.number_field :balance, 
      step: 0.01,
      value: trader.balance || 50000,
      class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-blue-500 focus:border-blue-500",
      placeholder: "Enter initial balance" %>
  <% unless trader.persisted? %>
    <p class="mt-1 text-xs text-gray-500">Default: $50,000.00</p>
  <% end %>
</div>