<div class="mb-8">
  <div class="flex justify-between items-start">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">
        <%= @trader.first_name %> <%= @trader.last_name %>
      </h1>
      <p class="mt-2 text-gray-600"><%= @trader.email %></p>
    </div>
    <div class="flex space-x-3">
      <%= link_to "Edit Trader", edit_admin_trader_path(@trader), 
          class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
      <% unless @trader.is_approve? %>
        <%= link_to "Approve", approve_admin_trader_path(@trader), 
            method: :patch,
            data: { confirm: "Are you sure you want to approve this trader?" },
            class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700" %>
      <% else %>
        <%= link_to "Reject", reject_admin_trader_path(@trader), 
            method: :patch,
            data: { confirm: "Are you sure you want to reject this trader?" },
            class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700" %>
      <% end %>
    </div>
  </div>
</div>

<!-- Trader Status Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center">
      <div class="p-2 <%= @trader.confirmed_at ? 'bg-green-100' : 'bg-yellow-100' %> rounded-lg">
        <svg class="h-6 w-6 <%= @trader.confirmed_at ? 'text-green-600' : 'text-yellow-600' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
        </svg>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-600">Email Status</p>
        <p class="text-lg font-semibold <%= @trader.confirmed_at ? 'text-green-600' : 'text-yellow-600' %>">
          <%= @trader.confirmed_at ? 'Confirmed' : 'Unconfirmed' %>
        </p>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center">
      <div class="p-2 <%= @trader.is_approve? ? 'bg-green-100' : 'bg-red-100' %> rounded-lg">
        <svg class="h-6 w-6 <%= @trader.is_approve? ? 'text-green-600' : 'text-red-600' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= @trader.is_approve? ? 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' : 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' %>"></path>
        </svg>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-600">Approval Status</p>
        <p class="text-lg font-semibold <%= @trader.is_approve? ? 'text-green-600' : 'text-red-600' %>">
          <%= @trader.is_approve? ? 'Approved' : 'Pending' %>
        </p>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center">
      <div class="p-2 bg-blue-100 rounded-lg">
        <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
        </svg>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-600">Current Balance</p>
        <p class="text-lg font-semibold text-gray-900">$<%= number_with_precision(@trader.balance, precision: 2) %></p>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center">
      <div class="p-2 bg-purple-100 rounded-lg">
        <svg class="h-6 w-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
        </svg>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-600">Portfolio Value</p>
        <p class="text-lg font-semibold text-gray-900">$<%= number_with_precision(@trader_stats[:portfolio_value], precision: 2) %></p>
      </div>
    </div>
  </div>
</div>

<!-- Trader Information -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
      <h3 class="text-lg font-semibold text-gray-900">Trader Details</h3>
    </div>
    <div class="p-6 space-y-4">
      <div>
        <p class="text-sm font-medium text-gray-500">Full Name</p>
        <p class="text-sm text-gray-900"><%= @trader.first_name %> <%= @trader.last_name %></p>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-500">Email Address</p>
        <p class="text-sm text-gray-900"><%= @trader.email %></p>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-500">Registration Date</p>
        <p class="text-sm text-gray-900"><%= @trader.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
      </div>
      <% if @trader.confirmed_at %>
        <div>
          <p class="text-sm font-medium text-gray-500">Email Confirmed</p>
          <p class="text-sm text-gray-900"><%= @trader.confirmed_at.strftime("%B %d, %Y at %I:%M %p") %></p>
        </div>
      <% end %>
    </div>
  </div>

  <div class="lg:col-span-2 bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
      <h3 class="text-lg font-semibold text-gray-900">Trading Statistics</h3>
    </div>
    <div class="p-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="text-center">
          <p class="text-2xl font-bold text-gray-900"><%= @trader_stats[:total_transactions] %></p>
          <p class="text-sm text-gray-500">Total Transactions</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-green-600"><%= @trader_stats[:total_buy_transactions] %></p>
          <p class="text-sm text-gray-500">Buy Orders</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-red-600"><%= @trader_stats[:total_sell_transactions] %></p>
          <p class="text-sm text-gray-500">Sell Orders</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-blue-600"><%= @trader.portfolios.count %></p>
          <p class="text-sm text-gray-500">Active Positions</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Recent Transactions -->
<div class="bg-white rounded-lg shadow mb-8">
  <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
    <h3 class="text-lg font-semibold text-gray-900">Recent Transactions</h3>
    <%= link_to "View All", admin_transactions_path(trader_id: @trader.id), 
        class: "text-blue-600 hover:text-blue-800 text-sm font-medium" %>
  </div>
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Stock</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Quantity</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Price</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Total</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @trader_transactions.each do |transaction| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap">
              <div>
                <p class="text-sm font-medium text-gray-900"><%= transaction.stock_symbol %></p>
                <p class="text-xs text-gray-500"><%= transaction.company_name %></p>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full <%= transaction.transaction_type == 'buy' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                <%= transaction.transaction_type.capitalize %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <%= transaction.quantity %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              $<%= number_with_precision(transaction.price_at_time, precision: 2) %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              $<%= number_with_precision(transaction.total_amount, precision: 2) %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= transaction.created_at.strftime("%m/%d/%Y %I:%M %p") %>
            </td>
          </tr>
        <% end %>
        
        <% if @trader_transactions.empty? %>
          <tr>
            <td colspan="6" class="px-6 py-4 text-center text-gray-500">
              No transactions found
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<!-- Current Portfolio -->
<div class="bg-white rounded-lg shadow">
  <div class="px-6 py-4 border-b border-gray-200">
    <h3 class="text-lg font-semibold text-gray-900">Current Portfolio</h3>
  </div>
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Stock</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Quantity</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Current Price</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Total Value</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Added</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @trader_portfolios.each do |portfolio| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap">
              <div>
                <p class="text-sm font-medium text-gray-900"><%= portfolio.stock_symbol %></p>
                <p class="text-xs text-gray-500"><%= portfolio.company_name %></p>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <%= portfolio.quantity %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              $<%= number_with_precision(portfolio.current_price, precision: 2) %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              $<%= number_with_precision(portfolio.total_amount, precision: 2) %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= portfolio.created_at.strftime("%m/%d/%Y") %>
            </td>
          </tr>
        <% end %>
        
        <% if @trader_portfolios.empty? %>
          <tr>
            <td colspan="5" class="px-6 py-4 text-center text-gray-500">
              No portfolio positions
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>