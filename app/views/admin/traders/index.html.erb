<div class="mb-8">
  <div class="flex justify-between items-center">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">All Traders</h1>
      <p class="mt-2 text-gray-600">Manage all trader accounts</p>
    </div>
    <%= link_to "Add New Trader", new_admin_trader_path, 
        class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
  </div>
</div>

<!-- Ransack Search Form -->
<div class="bg-white rounded-lg shadow-sm border border-gray-100 mb-6">
  <div class="p-6">
    <%= search_form_for @q, url: admin_traders_path, local: true, class: "grid grid-cols-1 md:grid-cols-4 gap-6" do |f| %>
      <!-- Search by name or email -->
      <div>
        <%= f.search_field :first_name_or_last_name_or_email_cont,
            placeholder: "Search name or email...",
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 shadow-sm" %>
      </div>
      
      <!-- Filter by approval status -->
      <div>
        <%= f.select :is_approve_eq,
            options_for_select([
              ['All Status', ''],
              ['Approved', true],
              ['Pending Approval', false]
            ], f.object.is_approve_eq),
            {},
            { class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 shadow-sm bg-white appearance-none" } %>
      </div>
      
      <!-- Filter by email confirmation -->
      <div>
        <%= f.select :confirmed_at_null,
            options_for_select([
              ['All Email Status', ''],
              ['Email Confirmed', false],
              ['Email Unconfirmed', true]
            ], f.object.confirmed_at_null),
            {},
            { class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 shadow-sm bg-white appearance-none" } %>
      </div>
      
      <!-- Search and Clear buttons -->
      <div class="flex space-x-2">
        <%= f.submit "Search", class: "flex-1 px-4 py-3 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200 shadow-sm" %>
        <%= link_to "Clear", admin_traders_path, class: "flex-1 px-4 py-3 bg-gray-100 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 transition-all duration-200 shadow-sm text-center" %>
      </div>
    <% end %>
  </div>
</div>

<!-- Traders Table -->
<div class="bg-white rounded-lg shadow overflow-hidden">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            <%= sort_link(@q, :first_name, "Trader") %>
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Approval Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            <%= sort_link(@q, :balance, "Balance") %>
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            <%= sort_link(@q, :created_at, "Registered") %>
          </th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @traders.each do |trader| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="flex items-center">
                <div class="h-10 w-10 bg-gray-300 rounded-full flex items-center justify-center">
                  <span class="text-sm font-medium text-gray-700">
                    <%= trader.first_name.first %><%= trader.last_name.first %>
                  </span>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-900">
                    <%= trader.first_name %> <%= trader.last_name %>
                  </p>
                  <p class="text-sm text-gray-500"><%= trader.email %></p>
                </div>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <%= render 'admin/shared/email_status_badge', user: trader %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <%= render 'admin/shared/status_badge', user: trader %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              $<%= number_with_precision(trader.balance, precision: 2) %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= trader.created_at.strftime("%m/%d/%Y") %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              <div class="flex items-center justify-end space-x-3">
                <%= link_to "View", admin_trader_path(trader), 
                    class: "inline-flex items-center px-3 py-1.5 border border-gray-300 text-xs font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 transition-colors duration-150" %>
                <%= link_to "Edit", edit_admin_trader_path(trader), 
                    class: "inline-flex items-center px-3 py-1.5 border border-amber-300 text-xs font-medium rounded-md text-amber-700 bg-amber-50 hover:bg-amber-100 transition-colors duration-150" %>
              </div>
            </td>
          </tr>
        <% end %>
        
        <% if @traders.empty? %>
          <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden">
            <div class="text-center py-16">
              <svg class="mx-auto h-16 w-16 text-gray-300 mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM9 9a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">
                <% if params[:q].present? %>
                  No traders match your search
                <% else %>
                  No traders found
                <% end %>
              </h3>
              <p class="text-gray-500 mb-6 max-w-sm mx-auto">
                <% if params[:q].present? %>
                  Try adjusting your search criteria to find what you're looking for.
                <% else %>
                  Get started by adding your first trader to the platform.
                <% end %>
              </p>
              <div class="flex flex-col sm:flex-row gap-3 justify-center">
                <% if params[:q].present? %>
                  <%= link_to "Clear Search", admin_traders_path, 
                      class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 transition-colors duration-200" %>
                <% end %>
                <%= link_to "Add New Trader", new_admin_trader_path, 
                    class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 transition-colors duration-200" %>
              </div>
            </div>
          </div>
        <% end %>
      </tbody>
    </table>
  </div>
</div>