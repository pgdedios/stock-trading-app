<!DOCTYPE html>
<html>
  <head>
    <title>Stock Trading App - Admin Panel</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body class="bg-gray-100">
    <!-- Admin Navigation -->
    <nav class="bg-blue-800 text-white shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex items-center">
            <%= link_to admin_root_path, class: "flex items-center space-x-2" do %>
              <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              </svg>
              <span class="text-xl font-bold">Admin Panel</span>
            <% end %>
          </div>
          
          <div class="flex items-center space-x-4">
            <!-- Navigation Links -->
            <div class="hidden md:flex items-center space-x-4">
              <%= link_to "Dashboard", admin_root_path, 
                  class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-blue-700 #{'bg-blue-700' if current_page?(admin_root_path)}" %>
              <%= link_to "All Traders", admin_traders_path, 
                  class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-blue-700 #{'bg-blue-700' if current_page?(admin_traders_path)}" %>
              <%= link_to "Pending Approvals", admin_pending_traders_path, 
                  class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-blue-700 #{'bg-blue-700' if current_page?(admin_pending_traders_path)}" %>
              <%= link_to "Transactions", admin_transactions_path, 
                  class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-blue-700 #{'bg-blue-700' if current_page?(admin_transactions_path)}" %>
            </div>
            
            <!-- User Menu -->
            <div class="flex items-center space-x-3">
              <span class="text-sm">Hello, <%= current_user.first_name %></span>
              <%= link_to "Logout", destroy_user_session_path, data: { "turbo-method": :delete }, 
                  class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-red-700 bg-red-600" %>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <!-- Flash Messages -->
    <% if notice %>
      <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mx-4 mt-4" role="alert">
        <span class="block sm:inline"><%= notice %></span>
      </div>
    <% end %>
    
    <% if alert %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mx-4 mt-4" role="alert">
        <span class="block sm:inline"><%= alert %></span>
      </div>
    <% end %>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8">
      <%= yield %>
    </main>
  </body>
</html>