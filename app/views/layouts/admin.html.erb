<!DOCTYPE html>
<html>
  <head>
    <title>Stock Trading App - Admin Panel</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100">
    <!-- Admin Navigation -->
    <nav class="bg-blue-800 text-white shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex items-center">
            <%= link_to admin_root_path, class: "flex items-center space-x-2" do %>
              <svg class="h-9 w-9 white mr-2 draw-line" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
              <span class="text-xl font-bold">Stock Trading App - Admin Panel</span>
            <% end %>
          </div>
          
          <div class="flex items-center space-x-4">
            <!-- Navigation Links -->
            <div class="hidden md:flex items-center space-x-3">
              <%= link_to "Dashboard", admin_root_path,
                  class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-blue-700 transition-colors duration-200 #{'bg-blue-700' if current_page?(admin_root_path)}" %>
              <%= link_to "All Traders", admin_traders_path,
                  class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-blue-700 transition-colors duration-200 #{'bg-blue-700' if current_page?(admin_traders_path)}" %>
              <%= link_to "Pending Approvals", admin_pending_traders_path,
                  class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-blue-700 transition-colors duration-200 #{'bg-blue-700' if current_page?(admin_pending_traders_path)}" %>
              <%= link_to "Transactions", admin_transactions_path,
                  class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-blue-700 transition-colors duration-200 #{'bg-blue-700' if current_page?(admin_transactions_path)}" %>
            </div>
            
            <!-- User Menu -->
            <div class="flex items-center space-x-4 border-l border-blue-700 pl-6">
              <div class="flex items-center space-x-2">
                <!-- User Avatar -->
                <div class="w-8 h-8 bg-blue-600 rounded-full flex items-center justify-center ring-2 ring-blue-500">
                  <span class="text-sm font-semibold">
                    <%= current_user.first_name.first %><%= current_user.last_name.first %>
                  </span>
                </div>
                <!-- User Greeting -->
                <span class="text-sm font-medium">Hello, <%= current_user.first_name %></span>
              </div>
              
              <!-- Logout Button -->
              <%= link_to "Logout", destroy_user_session_path, 
                  data: { "turbo-method": :delete },
                  class: "px-4 py-2 rounded-md text-sm font-medium bg-red-600 hover:bg-red-700 transition-colors duration-200 shadow-sm" %>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <!-- Flash Messages -->
    <% if notice %>
      <div class="bg-green-50 border-l-4 border-green-400 p-4 mx-4 mt-4 rounded-r-md shadow-sm">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
            </svg>
          </div>
          <div class="ml-3">
            <p class="text-sm text-green-700 font-medium"><%= notice %></p>
          </div>
        </div>
      </div>
    <% end %>
    
    <% if alert %>
      <div class="bg-red-50 border-l-4 border-red-400 p-4 mx-4 mt-4 rounded-r-md shadow-sm">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
            </svg>
          </div>
          <div class="ml-3">
            <p class="text-sm text-red-700 font-medium"><%= alert %></p>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
      <%= yield %>
    </main>
  </body>
</html>