<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">Admin Dashboard</h1>
  <p class="mt-2 text-gray-600">Overview of your stock trading platform</p>
</div>

<!-- Statistics Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center">
      <div class="p-2 bg-blue-100 rounded-lg">
        <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"></path>
        </svg>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-600">Total Traders</p>
        <p class="text-2xl font-semibold text-gray-900"><%= @stats[:total_traders] %></p>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center">
      <div class="p-2 bg-yellow-100 rounded-lg">
        <svg class="h-6 w-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-600">Pending Approvals</p>
        <p class="text-2xl font-semibold text-gray-900"><%= @stats[:pending_traders] %></p>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center">
      <div class="p-2 bg-green-100 rounded-lg">
        <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-600">Approved Traders</p>
        <p class="text-2xl font-semibold text-gray-900"><%= @stats[:approved_traders] %></p>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center">
      <div class="p-2 bg-purple-100 rounded-lg">
        <svg class="h-6 w-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
        </svg>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-600">Total Transactions</p>
        <p class="text-2xl font-semibold text-gray-900"><%= @stats[:total_transactions] %></p>
      </div>
    </div>
  </div>
</div>

<!-- Quick Actions -->
<div class="bg-white rounded-lg shadow mb-8">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-900">Quick Actions</h2>
  </div>
  <div class="p-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <%= link_to admin_pending_traders_path, class: "block p-4 border-2 border-dashed border-gray-300 rounded-lg hover:border-blue-400 hover:bg-blue-50 transition-colors" do %>
        <div class="text-center">
          <svg class="mx-auto h-8 w-8 text-gray-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <p class="text-sm font-medium text-gray-900">Review Pending Traders</p>
          <p class="text-xs text-gray-500"><%= @stats[:pending_traders] %> waiting for approval</p>
        </div>
      <% end %>

      <%= link_to new_admin_trader_path, class: "block p-4 border-2 border-dashed border-gray-300 rounded-lg hover:border-blue-400 hover:bg-blue-50 transition-colors" do %>
        <div class="text-center">
          <svg class="mx-auto h-8 w-8 text-gray-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
          </svg>
          <p class="text-sm font-medium text-gray-900">Add New Trader</p>
          <p class="text-xs text-gray-500">Manually create trader account</p>
        </div>
      <% end %>

      <%= link_to admin_transactions_path, class: "block p-4 border-2 border-dashed border-gray-300 rounded-lg hover:border-blue-400 hover:bg-blue-50 transition-colors" do %>
        <div class="text-center">
          <svg class="mx-auto h-8 w-8 text-gray-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
          </svg>
          <p class="text-sm font-medium text-gray-900">View Transactions</p>
          <p class="text-xs text-gray-500">Monitor all trading activity</p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Recent Transactions -->
<div class="bg-white rounded-lg shadow">
  <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
    <h2 class="text-lg font-semibold text-gray-900">Recent Transactions</h2>
    <%= link_to "View All", admin_transactions_path, class: "text-blue-600 hover:text-blue-800 text-sm font-medium" %>
  </div>
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Trader</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Stock</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Quantity</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @stats[:recent_transactions].each do |transaction| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="flex items-center">
                <div class="h-8 w-8 bg-gray-300 rounded-full flex items-center justify-center">
                  <span class="text-sm font-medium text-gray-700">
                    <%= transaction.user.first_name.first %><%= transaction.user.last_name.first %>
                  </span>
                </div>
                <div class="ml-3">
                  <p class="text-sm font-medium text-gray-900">
                    <%= transaction.user.first_name %> <%= transaction.user.last_name %>
                  </p>
                  <p class="text-xs text-gray-500"><%= transaction.user.email %></p>
                </div>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div>
                <p class="text-sm font-medium text-gray-900"><%= transaction.stock_symbol %></p>
                <p class="text-xs text-gray-500"><%= transaction.company_name %></p>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full <%= transaction.transaction_type == 'buy' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                <%= transaction.transaction_type.capitalize %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <%= transaction.quantity %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              $<%= number_with_precision(transaction.total_amount, precision: 2) %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= transaction.created_at.strftime("%m/%d/%Y %I:%M %p") %>
            </td>
          </tr>
        <% end %>
        
        <% if @stats[:recent_transactions].empty? %>
          <tr>
            <td colspan="6" class="px-6 py-4 text-center text-gray-500">
              No transactions found
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>